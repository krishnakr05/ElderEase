<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    ```
    <!-- ================= PERMISSIONS ================= -->

    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.SEND_SMS"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- LOCATION PERMISSIONS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- Telephony optional -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Queries for Android 11+ -->
    <queries>

        <intent>
            <action android:name="android.intent.action.DIAL"/>
        </intent>

        <intent>
            <action android:name="android.intent.action.CALL"/>
        </intent>

        <provider android:authorities="com.android.contacts"/>

    </queries>

    <!-- ================= APPLICATION ================= -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ElderEase"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ElderEase">

        <!-- MAIN LAUNCHER -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- HOME -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="true"/>

        <!-- EMERGENCY -->
        <activity
            android:name=".ui.emergency.EmergencyActivity"
            android:exported="false"/>

        <!-- VIEW SOS CONTACTS -->
        <activity
            android:name=".ui.emergency.ViewEmergencyContactsActivity"
            android:exported="false"/>

        <!-- APP SETUP -->
        <activity
            android:name=".ui.setup.SetupAppsActivity"
            android:exported="false"/>

        <!-- FAVOURITE CONTACT SETUP -->
        <activity
            android:name=".ui.setup.FavouriteContactSetupActivity"
            android:exported="false"/>

        <!-- SOS CONTACT SETUP -->
        <activity
            android:name=".ui.setup.ContactSetupActivity"
            android:exported="false"/>

        <!-- VOICE HELP -->
        <activity
            android:name=".ui.voice.VoiceHelpActivity"
            android:exported="false"/>

        <!-- CAREGIVER LOGIN -->
        <activity
            android:name=".ui.caregiver.CaregiverLoginActivity"
            android:exported="false"/>

        <!-- CAREGIVER SETTINGS -->
        <activity
            android:name=".ui.caregiver.CaregiverSettingsActivity"
            android:exported="false"/>

        <!-- SETTINGS -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"/>

        <!-- CONTACTS -->
        <activity
            android:name=".ui.contacts.ContactsActivity"
            android:exported="false"/>

        <!-- ALL APPS -->
        <activity
            android:name=".ui.allapps.AllAppsActivity"
            android:exported="false"/>

    </application>
    ```

</manifest>
