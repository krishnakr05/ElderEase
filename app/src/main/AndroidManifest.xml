<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================= PERMISSIONS ================= -->

    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.SEND_SMS"/>
    <uses-permission android:name="android.permission.INTERNET"/>

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- ================= APPLICATION ================= -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ElderEase"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ElderEase">

        <!-- LAUNCHER -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- HOME -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="true"/>

        <!-- EMERGENCY -->
        <activity
            android:name=".ui.emergency.EmergencyActivity"
            android:exported="false"/>

        <!-- APPS SETUP -->
        <activity
            android:name=".ui.setup.SetupAppsActivity"
            android:exported="false"/>

        <!-- FAVOURITE CONTACT SETUP -->
        <activity
            android:name=".ui.setup.FavouriteContactSetupActivity"
            android:exported="false"/>

        <!-- SOS CONTACT SETUP -->
        <activity
            android:name=".ui.setup.ContactSetupActivity"
            android:exported="false"/>

        <!-- SETTINGS -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"/>

        <!-- CONTACTS SCREEN -->
        <activity
            android:name=".ui.contacts.ContactsActivity"
            android:exported="false"/>

        <!-- ALL APPS -->
        <activity
            android:name=".ui.allapps.AllAppsActivity"
            android:exported="false"/>

    </application>

</manifest>