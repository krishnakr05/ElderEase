<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP BAR -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_media_previous"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ElderEase"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>

        <!-- TITLE -->
        <TextView
            android:id="@+id/txtInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap the microphone to speak"
            android:textStyle="bold"
            android:textSize="26sp"
            android:gravity="center"
            android:textColor="#111827"
            android:layout_marginTop="40dp"/>

        <!-- MIC CIRCLE -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_mic_circle"
            android:elevation="6dp">

            <ImageView
                android:id="@+id/btnMic"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_btn_speak_now"/>
        </FrameLayout>

        <!-- RESULT TEXT -->
        <TextView
            android:id="@+id/txtResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for command..."
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:textColor="#0F172A"/>

        <!-- STOP BUTTON -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Stop Listening"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_stop_button"/>

    </LinearLayout>

</ScrollView>